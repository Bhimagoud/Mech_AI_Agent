# =============================================================
#  NBA PEO-Mission Mapping Engine — Environment Configuration
#  Copy this file to .env and fill in your real keys.
#  NEVER commit .env to git — it is in .gitignore
# =============================================================

# ─── LLM Provider ────────────────────────────────────────────
# Choose one: anthropic | groq
LLM_PROVIDER=anthropic

# ─── Anthropic (Claude) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096

# ─── Groq ────────────────────────────────────────────────────
# Fast inference on open-source models (llama-3, mixtral, etc.)
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_MAX_TOKENS=4096

# ─── RAG (Retrieval-Augmented Generation) ────────────────────
# Chunk size in characters for document splitting
RAG_CHUNK_SIZE=1500
# Character overlap between adjacent chunks
RAG_CHUNK_OVERLAP=200
# Number of chunks retrieved per query
RAG_TOP_K=4
# Sentence-transformers model for local embeddings (no API cost)
RAG_EMBED_MODEL=all-MiniLM-L6-v2

# ─── Flask Server ────────────────────────────────────────────
PORT=5000
DEBUG=false
